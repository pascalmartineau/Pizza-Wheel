<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Which daughter should I Expropriate?</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Fredoka:wght@400;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --red: #c62828;
      --green: #2e7d32;
      --cream: #fff3e0;
      --cheese: #f7c948;
      --crust: #d28b36;
      --pepperoni: #b71c1c;
      --olive: #2f3e2f;
      --text: #3b2a1a;
      --gold: #ffd54f;
    }
    * {
      box-sizing: border-box;
    }
    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Fredoka", sans-serif;
      background:
        radial-gradient(circle at top, rgba(255,255,255,0.5), transparent 30%),
        linear-gradient(135deg, #fdf1d6, #f7e3b5);
      color: var(--text);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      overflow-x: hidden;
    }
    .app {
      width: 100%;
      max-width: 900px;
      text-align: center;
      background: rgba(255, 248, 230, 0.88);
      border: 6px solid #8d6e63;
      border-radius: 28px;
      padding: 28px 20px 36px;
      box-shadow: 0 18px 45px rgba(0,0,0,0.18);
      position: relative;
    }
    .flag-bar {
      height: 14px;
      width: 100%;
      border-radius: 999px;
      margin-bottom: 16px;
      background: linear-gradient(
        90deg,
        var(--green) 0 33.33%,
        #f8f4e8 33.33% 66.66%,
        var(--red) 66.66% 100%
      );
    }
    h1 {
      font-family: "Playfair Display", serif;
      font-size: clamp(2rem, 5vw, 3.5rem);
      margin: 8px 0 12px;
      color: var(--red);
      text-shadow: 2px 2px 0 #fff;
    }
    .subtitle {
      margin: 0 auto 20px;
      max-width: 650px;
      font-size: 1.05rem;
      color: #6d4c41;
    }
    .wheel-wrap {
      position: relative;
      width: min(78vw, 460px);
      height: min(78vw, 460px);
      margin: 26px auto 18px;
    }
    .pointer {
      position: absolute;
      top: -8px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      width: 0;
      height: 0;
      border-left: 22px solid transparent;
      border-right: 22px solid transparent;
      border-top: 44px solid var(--red);
      filter: drop-shadow(0 3px 2px rgba(0,0,0,0.25));
    }
    .wheel {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: 14px solid var(--crust);
      box-shadow:
        inset 0 0 0 8px #f3b562,
        0 10px 30px rgba(0,0,0,0.25);
      position: relative;
      overflow: hidden;
      transition: transform 4.8s cubic-bezier(0.15, 0.85, 0.18, 1);
      background: conic-gradient(
        #f9d65c 0deg 60deg,
        #f7c948 60deg 120deg,
        #f9d65c 120deg 180deg,
        #f7c948 180deg 240deg,
        #f9d65c 240deg 300deg,
        #f7c948 300deg 360deg
      );
    }
    /* slice separator lines */
    .wheel::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 50%;
      background:
        conic-gradient(
          transparent 0deg 59deg,
          rgba(125, 74, 22, 0.9) 59deg 61deg,
          transparent 61deg 119deg,
          rgba(125, 74, 22, 0.9) 119deg 121deg,
          transparent 121deg 179deg,
          rgba(125, 74, 22, 0.9) 179deg 181deg,
          transparent 181deg 239deg,
          rgba(125, 74, 22, 0.9) 239deg 241deg,
          transparent 241deg 299deg,
          rgba(125, 74, 22, 0.9) 299deg 301deg,
          transparent 301deg 359deg,
          rgba(125, 74, 22, 0.9) 359deg 360deg
        );
      pointer-events: none;
    }
    .center {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 90px;
      height: 90px;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle, #fff4c4, #f0b84c);
      border: 8px solid #8d6e63;
      border-radius: 50%;
      z-index: 3;
      display: grid;
      place-items: center;
      font-weight: 700;
      color: #6d4c41;
      box-shadow: 0 5px 12px rgba(0,0,0,0.15);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-size: 0.8rem;
    }
    .label {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 140px;
      margin-left: -70px;
      transform-origin: center center;
      font-weight: 700;
      font-size: clamp(1rem, 2vw, 1.2rem);
      color: #5d4037;
      text-shadow: 1px 1px 0 rgba(255,255,255,0.7);
      z-index: 2;
      pointer-events: none;
    }
    .label span {
      display: block;
      transform: translateY(-150px);
    }
    .pep {
      position: absolute;
      width: 28px;
      height: 28px;
      background: radial-gradient(circle at 30% 30%, #d84343, var(--pepperoni));
      border-radius: 50%;
      box-shadow: inset -2px -3px 0 rgba(0,0,0,0.15);
      opacity: 0.95;
    }
    .olive {
      position: absolute;
      width: 14px;
      height: 14px;
      border: 4px solid var(--olive);
      border-radius: 50%;
      opacity: 0.7;
    }
    .basil {
      position: absolute;
      width: 16px;
      height: 26px;
      background: linear-gradient(180deg, #43a047, #1b5e20);
      border-radius: 50% 50% 50% 50% / 70% 70% 30% 30%;
      transform: rotate(20deg);
      opacity: 0.8;
    }
    .controls {
      margin-top: 20px;
    }
    button {
      font-family: inherit;
      font-size: 1.15rem;
      font-weight: 700;
      padding: 14px 30px;
      border: none;
      border-radius: 999px;
      background: linear-gradient(180deg, var(--green), #1b5e20);
      color: white;
      cursor: pointer;
      box-shadow: 0 8px 16px rgba(46, 125, 50, 0.35);
      transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.2s;
    }
    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 18px rgba(46, 125, 50, 0.42);
    }
    button:active {
      transform: translateY(1px);
    }
    button:disabled {
      opacity: 0.65;
      cursor: not-allowed;
      transform: none;
    }
    .result {
      min-height: 52px;
      margin-top: 18px;
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--red);
    }
    .small {
      margin-top: 8px;
      color: #795548;
      font-size: 0.95rem;
    }
    .italian-note {
      margin-top: 18px;
      font-size: 0.95rem;
      color: #6d4c41;
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="flag-bar"></div>
    <h1>Which daughter should I Expropriate?</h1>
    <p class="subtitle">
      The Pizza Council of Italy shall decide.
    </p>
    <div class="wheel-wrap">
      <div class="pointer"></div>
      <div class="wheel" id="wheel">
        <div class="label" style="transform: translate(-50%, -50%) rotate(30deg);"><span>Sophia</span></div>
        <div class="label" style="transform: translate(-50%, -50%) rotate(90deg);"><span>Courtney</span></div>
        <div class="label" style="transform: translate(-50%, -50%) rotate(150deg);"><span>Sophia</span></div>
        <div class="label" style="transform: translate(-50%, -50%) rotate(210deg);"><span>Courtney</span></div>
        <div class="label" style="transform: translate(-50%, -50%) rotate(270deg);"><span>Sophia</span></div>
        <div class="label" style="transform: translate(-50%, -50%) rotate(330deg);"><span>Courtney</span></div>
        <div class="pep" style="top: 70px; left: 160px;"></div>
        <div class="pep" style="top: 110px; left: 270px;"></div>
        <div class="pep" style="top: 210px; left: 300px;"></div>
        <div class="pep" style="top: 315px; left: 245px;"></div>
        <div class="pep" style="top: 315px; left: 125px;"></div>
        <div class="pep" style="top: 215px; left: 75px;"></div>
        <div class="pep" style="top: 120px; left: 95px;"></div>
        <div class="olive" style="top: 88px; left: 218px;"></div>
        <div class="olive" style="top: 160px; left: 322px;"></div>
        <div class="olive" style="top: 290px; left: 282px;"></div>
        <div class="olive" style="top: 332px; left: 188px;"></div>
        <div class="olive" style="top: 270px; left: 92px;"></div>
        <div class="olive" style="top: 160px; left: 100px;"></div>
        <div class="basil" style="top: 135px; left: 205px;"></div>
        <div class="basil" style="top: 250px; left: 250px;"></div>
        <div class="basil" style="top: 230px; left: 135px;"></div>
        <div class="center">Pizza</div>
      </div>
    </div>
    <div class="controls">
      <button id="spinBtn">Choose</button>
      <div class="result" id="result"></div>
      <div class="small">Mamma mia... destiny is baking.</div>
      <div class="italian-note">🇮🇹 Buona fortuna 🇮🇹</div>
    </div>
  </div>
  <script>
    const wheel = document.getElementById("wheel");
    const spinBtn = document.getElementById("spinBtn");
    const result = document.getElementById("result");
    const names = ["Sophia", "Courtney", "Sophia", "Courtney", "Sophia", "Courtney"];
    const sliceAngle = 60;
    let currentRotation = 0;
    let spinning = false;
    function spinWheel() {
      if (spinning) return;
      spinning = true;
      spinBtn.disabled = true;
      result.textContent = "";
      const winningIndex = Math.floor(Math.random() * 6);
      // Pointer is at top. Slice centers are at:
      // 30, 90, 150, 210, 270, 330 degrees
      // We rotate so the winning slice center lands at 0/top.
      const targetSliceCenter = winningIndex * sliceAngle + 30;
      const extraSpins = 360 * (5 + Math.floor(Math.random() * 3)); // 5-7 spins
      const finalRotation = extraSpins + (360 - targetSliceCenter);
      currentRotation += finalRotation;
      wheel.style.transform = `rotate(${currentRotation}deg)`;
      setTimeout(() => {
        const winner = names[winningIndex];
        result.textContent = `🤌 The pizza chooses: ${winner}!`;
        spinBtn.disabled = false;
        spinning = false;
      }, 4900);
    }
    spinBtn.addEventListener("click", spinWheel);
  </script>
</body>
</html>
